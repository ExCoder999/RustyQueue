# Copy to .env and fill in real values before running locally.
# The app also reads RUSTYQUEUE__* vars directly; these aliases are for sqlx-cli.

DATABASE_URL=postgres://rustyqueue:rustyqueue@localhost:5432/rustyqueue

RUSTYQUEUE__DATABASE__URL=postgres://rustyqueue:rustyqueue@localhost:5432/rustyqueue
RUSTYQUEUE__DATABASE__MAX_CONNECTIONS=20

RUSTYQUEUE__SERVER__HOST=0.0.0.0
RUSTYQUEUE__SERVER__PORT=8080

RUSTYQUEUE__WORKER__QUEUES=["default"]
RUSTYQUEUE__WORKER__NUM_WORKERS_PER_QUEUE=4

RUSTYQUEUE__QUEUE__DEFAULT_LEASE_SECONDS=60
RUSTYQUEUE__QUEUE__POLL_INTERVAL_MS=500
RUSTYQUEUE__QUEUE__MAX_COMMAND_TIMEOUT_SECONDS=300

RUST_LOG=info
